# ========================================
# SHOONYA API CREDENTIALS
# ========================================
# Get these from: https://shoonya.finvasia.com/

SHOONYA_USER_ID=your_user_id_here
SHOONYA_PASSWORD=your_password_here
SHOONYA_TOTP_KEY=your_totp_key_here
SHOONYA_VENDOR_CODE=your_vendor_code_here
SHOONYA_API_SECRET=your_api_secret_here

# ========================================
# TELEGRAM NOTIFICATIONS (Optional)
# ========================================
# Get bot token from: https://t.me/BotFather
# Get chat ID from: https://t.me/userinfobot

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=False

# ========================================
# INSTRUCTIONS
# ========================================
# 1. Copy this file to .env
# 2. Replace all "your_*_here" with actual values
# 3. Never commit .env file to Git!
# 4. Keep your credentials secure
