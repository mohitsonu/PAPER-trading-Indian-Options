# ========================================
# SENSITIVE DATA - NEVER COMMIT!
# ========================================

# Environment variables (contains API keys, passwords, TOTP)
.env

# Capital and trading data (root directory only)
/capital_persistence.json
/daily_capital_tracking.csv

# Trade history in root directory (contains real trading data)
/high_accuracy_trades_*.csv
/high_accuracy_updates_*.json
/simplified_trades_*.csv
/current_trades_*.csv

# Trade state files in root directory
/trade_state_*.json

# EXCEPTION: Allow trade journal folder files to be committed
!trade_journal/csv/*.csv
!trade_journal/json/*.json
!trade_journal/logs/*.log

# Session reports
trading_report*.html

